{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/html": [
      "default",
      {
        "ignore": [
          "script[type=module]"
        ]
      }
    ],
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "flex-direction",
          "scroll-behavior",
          "scroll-behavior: smooth",
          "padding-block",
          "width: fit-content",
          "gap",
          "pointer-events",
          "justify-content",
          "align-items",
          "background-position: center"
        ]
      }
    ]
  }
}