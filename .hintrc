{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/html": [
      "default",
      {
        "ignore": [
          "script[type=module]"
        ]
      }
    ],
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "flex-direction",
          "scroll-behavior",
          "scroll-behavior: smooth",
          "padding-block",
          "width: fit-content",
          "gap",
          "pointer-events",
          "justify-content",
          "align-items",
          "background-position: center",
          "inset",
          "position: sticky",
          "grid-template-columns",
          "display: grid",
          "resize",
          "grid-template-columns: repeat(3, 1fr)",
          "grid-column",
          "grid-template-columns: repeat(2, 1fr)",
          "object-fit",
          "object-fit: cover",
          "row-gap",
          "padding-inline",
          "grid-template-columns: repeat(2, minmax(0, 1fr))",
          "object-position",
          "aspect-ratio",
          "flex",
          "grid-template-columns: repeat(12, 1fr)",
          "text-align: center",
          "text-align: left",
          "margin-inline",
          "justify-items",
          "grid-template-columns: repeat(var(--colunas), 1fr)",
          "grid-template-columns: repeat(var(--columns), 1fr)"
        ]
      }
    ],
    "disown-opener": "off",
    "button-type": "off"
  }
}